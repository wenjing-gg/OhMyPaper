{
  "name": "deepxiv-client",
  "version": "2.0.1",
  "description": "DeepXiv cross-platform desktop client built with Electron and the official Python SDK",
  "author": "wenjing-gg",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wenjing-gg/DeepxivAPP.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run bridge:build && npm run renderer:build && electron .",
    "dev": "concurrently -k \"npm:renderer:dev\" \"npm:electron:dev\"",
    "electron:dev": "wait-on tcp:5173 && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "renderer:dev": "vite --config renderer/vite.config.js",
    "renderer:build": "vite build --config renderer/vite.config.js",
    "bridge:build": "node scripts/build_bridge.js",
    "test:ai-network": "node scripts/test_ai_network.js",
    "build:mac": "npm run bridge:build && npm run renderer:build && electron-builder --mac dir",
    "dist:mac": "npm run bridge:build && npm run renderer:build && electron-builder --mac dmg --publish never",
    "build:win": "npm run bridge:build && npm run renderer:build && electron-builder --win dir --x64",
    "dist:win": "npm run bridge:build && npm run renderer:build && electron-builder --win nsis --x64 --publish never"
  },
  "build": {
    "appId": "cn.rag.deepxiv.client",
    "productName": "DeepXiv Client",
    "asar": true,
    "asarUnpack": [
      "renderer/dist/assets/pdf.worker.min-*.mjs"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bridge-dist",
        "to": "bridge"
      }
    ],
    "mac": {
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.19",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "pdfjs-dist": "^5.6.205"
  }
}
