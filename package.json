{
  "name": "deepxiv-client",
  "version": "1.0.7",
  "description": "DeepXiv cross-platform desktop client built with Electron and the official Python SDK",
  "author": "wenjing-gg",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wenjing-gg/DeepxivAPP.git"
  },
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run renderer:build && electron .",
    "dev": "concurrently -k \"npm:renderer:dev\" \"npm:electron:dev\"",
    "electron:dev": "wait-on tcp:5173 && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "renderer:dev": "vite --config renderer/vite.config.js",
    "renderer:build": "vite build --config renderer/vite.config.js",
    "build:mac": "npm run renderer:build && electron-builder --mac dir",
    "dist:mac": "npm run renderer:build && electron-builder --mac dmg --publish never",
    "build:win": "npm run renderer:build && electron-builder --win dir",
    "dist:win": "npm run renderer:build && electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "cn.rag.deepxiv.client",
    "productName": "DeepXiv Client",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python"
      },
      {
        "from": ".venv",
        "to": ".venv"
      }
    ],
    "mac": {
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.19",
    "wait-on": "^8.0.3"
  }
}
